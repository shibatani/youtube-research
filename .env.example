# YouTube Data API v3 の API キー
# Google Cloud Console で取得: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google スプレッドシートのID
# スプレッドシートのURLから取得: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Turso (SQLite互換クラウドDB)
# turso db show [db-name] --url で取得
TURSO_DATABASE_URL=libsql://your-database.turso.io
# turso db tokens create [db-name] で取得
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Slack Webhook URL
# Slack App の Incoming Webhooks で取得
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# OpenAI API Key
# https://platform.openai.com/api-keys で取得
OPENAI_API_KEY=sk-...

# Fine-tuned Model ID（学習完了後に設定）
# OpenAI Dashboard で確認: https://platform.openai.com/finetune
# 未設定の場合、Stealth判定フィルタはスキップされます
FINETUNE_MODEL_ID=
